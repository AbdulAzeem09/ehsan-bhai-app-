    if(name == ""){
      var title = '<strong>Fill all required fields</strong>';
      var icon = '';
      showNofification(title, icon);
    }else{
      if(mobile == ""){
        var title = '<strong>Fill all required fields</strong>';
        var icon = '';
        showNofification(title, icon);
      }else{
        if(email == ""){
          var title = '<strong>Fill all required fields</strong>';
          var icon = '';
          showNofification(title, icon);
        }else{
          if(country < 1){
            var title = '<strong>Fill all required fields</strong>';
            var icon = '';
            showNofification(title, icon);
          }else{
            if(state < 1){
              var title = '<strong>Fill all required fields</strong>';
              var icon = '';
              showNofification(title, icon);
            }else{
              if(city < 1){
                var title = '<strong>Fill all required fields</strong>';
                var icon = '';
                showNofification(title, icon);
              }else{
                if(address == ""){
                  var title = '<strong>Fill all required fields</strong>';
                  var icon = '';
                  showNofification(title, icon);
                }else{
                  //===START FORM SUBMIT
                  $.post("addship.php", {name:name,mobile:mobile, email:email, country:country,state:state,city:city,address:address, txtUser:txtUser }, function (data) {
                    
                    var title = '<strong>Shipping Info Saved Successfully!</strong>';
                    var icon = '';
                    showNofification(title, icon);
                  });
                }
              }
            }
          }
        }
      }
    }
